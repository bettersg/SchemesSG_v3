{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development next dev",
    "build": "npm run clean && npm install && next build",
    "start": "cross-env NODE_ENV=production next start",
    "start:staging": "cross-env NODE_ENV=staging next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:staging": "cross-env APP_ENV=staging next build",
    "build:prod": "cross-env APP_ENV=production next build",
    "test-build:staging": "npm run build:staging && npx serve@latest out",
    "test-build:prod": "npm run build:prod && npx serve@latest out",
    "clean": "rm -rf node_modules .next out dist"
  },
  "dependencies": {
    "@heroui/react": "3.0.2",
    "@heroui/styles": "^3.0.4",
    "@lottiefiles/dotlottie-react": "^0.19.2",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/lodash": "^4.17.24",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
